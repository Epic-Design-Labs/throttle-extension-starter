{
  "name": "@starter/cloudflare",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "WRANGLER_LOG=none WRANGLER_SEND_METRICS=false wrangler deploy --dry-run --outdir dist",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@starter/adapters-cloudflare-queue": "workspace:*",
    "@starter/adapters-d1": "workspace:*",
    "@starter/contracts": "workspace:*",
    "@starter/core": "workspace:*",
    "@starter/demo-connector": "workspace:*",
    "@starter/security": "workspace:*",
    "@starter/throttle": "workspace:*",
    "hono": "^4.10.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20251210.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "4.54.0"
  }
}
