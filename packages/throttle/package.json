{
  "name": "@starter/throttle",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run",
    "test:consumer": "node --input-type=module -e \"const throttle = await import('@starter/throttle'); if (!throttle.verifyThrottleWebhook || !throttle.createExtensionIdentityVerifier) throw new Error('package root did not export throttle APIs')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@starter/contracts": "workspace:*",
    "@starter/core": "workspace:*",
    "jose": "^6.1.3",
    "zod": "^4.4.3"
  }
}
